{
  "expo": {
    "name": "Bookmarked",
    "slug": "bookmarked",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bookmarked",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-sharing",
      "expo-image",
      "expo-status-bar",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.spookiedawgtechie.bookmarked",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8235acf0-0da0-4bde-9642-4410b44292b2"
      }
    },
    "owner": "spookiedawgtechie"
  }
}
